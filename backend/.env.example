# UniPark API
API_TITLE=UniPark API
API_DESCRIPTION=University Parking Management System API
API_VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# PostgreSQL
DATABASE_URL=postgresql+psycopg://app_user:your_secure_password@localhost:5432/unipark_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false
SKIP_DB_INIT=false

# Auth
JWT_SECRET_KEY=change-this-to-a-long-random-secret-before-sharing
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log
